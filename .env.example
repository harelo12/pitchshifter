NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-strong-secret

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
FRONTEND_SUCCESS_REDIRECT=http://localhost:5173/auth/success
FRONTEND_FAILURE_REDIRECT=http://localhost:5173/auth/error

MAX_FILE_SIZE_MB=100
ALLOWED_INPUT_FORMATS=mp3,wav,flac,ogg,m4a,aac
ALLOWED_OUTPUT_FORMATS=wav,mp3,flac,ogg
DEFAULT_OUTPUT_FORMAT=wav
UPLOAD_DIR=/app/storage/uploads
PROCESSED_DIR=/app/storage/processed
TEMP_DIR=/app/storage/temp
KEEP_FILES_MINUTES=60

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=60

CORS_ALLOWED_ORIGINS=http://localhost:5173
